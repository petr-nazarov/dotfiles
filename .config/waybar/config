        "format-icons": {
            "headphone": "ï€¥",
            "hands-free": "َ°ڈ´",
            "headset": "َ°‹ژ",
            "phone": "ï‚•",
            "portable": "ï‚•",
            "car": "ï†¹",
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "on-click": "pavucontrol",
        "min-length": 13,
    },

    "custom/mem": {
        "format": "{} َ°چ›",
        "interval": 3,
        "exec": "free -h | awk '/Mem:/{printf $3}'",
